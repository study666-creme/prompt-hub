# 复制为 .dev.vars（勿提交 git）
# 阿里云控制台 → RDS Supabase → Settings → API Keys → Legacy service_role（不是 anon）

SUPABASE_URL=http://8.148.193.247:80
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SERVICE_ROLE_KEY

# 生图（GrsAI / Apimart，至少填一个才能调 /api/v1/generate）
IMAGE_API_KEY=
# APIMART_API_KEY=
# ITHINK_API_KEY=   # ThinkAI 经济线路（https://www.thinkai.tv/console/token）
# ITHINK_API_BASE_URL=https://www.thinkai.tv
# ITHINK_UPSTREAM_MODEL=gpt-image-2   # 模型广场里的 ID，不对时改这个
# MOOKO_API_KEY=   # 木瓜AI 线路（https://api.mooko.ai/pricing）
# MOOKO_API_BASE_URL=https://api.mooko.ai
# MOOKO_MAX_CONCURRENT_SUBMITS=8   # 慢速线并发 POST 上限（1–16，默认 8）

# 与线上一致：仅 R2（不写、不读 Supabase Storage，避免超额）
MEDIA_STORAGE_MODE=r2
# 本地 Miniflare R2 为空，签名 URL 走线上 CDN 出图（必填，默认即 api.prompt-hubs.com）
LOCAL_MEDIA_UPSTREAM=https://api.prompt-hubs.com

ENVIRONMENT=development
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://prompt-hubs.com,https://www.prompt-hubs.com
