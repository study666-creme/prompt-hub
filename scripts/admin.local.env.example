# 复制为 admin.local.env（勿提交 git）
# 用于 generate-codes.ps1、sync-supabase-to-r2.mjs、备份脚本

API_BASE_URL=https://api.prompt-hub.cn
ADMIN_API_SECRET=请与 wrangler secret put ADMIN_API_SECRET 保持一致

# Supabase 旧库（备份 / 迁出；迁完成后可删）
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# MemFire 新库（memfire-upload-storage.mjs · memfire-preflight.mjs）
MEMFIRE_URL=https://xxxxx.baseaf.memfiredb.com
MEMFIRE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2（仅 sync-supabase-to-r2.mjs 需要）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prompt-hub-card-images
