# 复制为 admin.local.env（勿提交 git）
# 用于运营、图片巡检和迁移脚本

API_BASE_URL=https://api.prompt-hubs.com
ADMIN_API_SECRET=请与 wrangler secret put ADMIN_API_SECRET 保持一致

# 当前 MemFire（变量名沿用 SUPABASE_* 兼容 SDK）
SUPABASE_URL=https://xxxxx.baseaf.memfiredb.com
SUPABASE_SERVICE_ROLE_KEY=
AUDIT_USER_ID=

# 仅在迁移/恢复对比另一个 MemFire 项目时填写
MEMFIRE_URL=https://xxxxx.baseaf.memfiredb.com
MEMFIRE_SERVICE_ROLE_KEY=

# Cloudflare R2（仅 sync-supabase-to-r2.mjs 需要）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prompt-hub-card-images
