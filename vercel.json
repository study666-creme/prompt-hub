{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/codex-remote", "destination": "https://infinite-canvas-jay.vercel.app/codex-remote" },
    { "source": "/codex-remote/:path*", "destination": "https://infinite-canvas-jay.vercel.app/codex-remote/:path*" },
    { "source": "/_next/:path*", "destination": "https://infinite-canvas-jay.vercel.app/_next/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
